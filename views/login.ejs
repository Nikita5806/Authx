<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
 
<body class="min-h-screen bg-slate-950 flex items-center justify-center">
  <div class="flex flex-col items-center">
    <form action="/login" method="post" class="bg-slate-100 p-8 rounded shadow-md w-full max-w-sm">
      <h2 class="text-2xl text-slate-900 font-bold mb-6 text-center">Authx.portal <br>Login Your account</h2>

     <label for="email" class="block mb-2">Email:</label>
      <input type="email" id="email" name="email" class="w-full mb-6 p-2 border border-gray-300 rounded">

      <label for="password" class="block mb-2">Password:</label>
      <input type="password" id="password" name="password" class="w-full mb-4 p-2 border border-gray-300 rounded">

      
      

      <button type="submit" value="create" class="w-full bg-slate-900 text-white p-2 rounded hover:bg-blue-600">
        Login
      </button>
    </form>

    <!-- Login text below form -->
    <p class="text-center text-white mt-4">
      Dont had an account?
      <a href="/" class="text-blue-400 hover:underline">Sign up</a>
    </p>
  </div>
</body>

</html>



